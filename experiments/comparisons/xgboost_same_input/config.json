{
  "experiment_name": "xgboost_same_input",
  "display_name": "XGBoost Same-Input Baseline",
  "experiment_type": "comparison",
  "runner": "xgboost",
  "description": "Tabular XGBoost baseline trained on the same unified cached inputs.",
  "dataset_parameters": "../../common/dataset_parameters.json",
  "seeds": [42],
