    "model_display_name": "XGBoost Same-Input Baseline",
    "include_target_context": true,
    "num_boost_round": 70,
    "early_stopping_rounds": 30,
    "params": {
      "objective": "binary:logistic",
      "eval_metric": "auc",
      "tree_method": "hist",
      "max_depth": 6,
      "eta": 0.05,
      "subsample": 0.9,
      "colsample_bytree": 0.9,
      "min_child_weight": 5.0,
      "lambda": 1.0,
      "alpha": 0.0
    }
  }
}
