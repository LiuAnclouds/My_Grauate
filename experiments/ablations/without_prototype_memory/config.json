{
  "experiment_name": "without_prototype_memory",
  "display_name": "DyRIFT-GNN Without Prototype Memory",
  "experiment_type": "ablation",
  "runner": "graph",
  "description": "Ablation that removes the prototype-memory representation regularizer while keeping the rest of DyRIFT intact.",
  "dataset_parameters": "../../common/dataset_parameters.json",
  "seeds": [42],
  "graph": {
    "engine_target": "dyrift_gnn",
    "model_display_name": "DyRIFT-GNN Without Prototype Memory",
    "backbone_display_name": "TRGT",
    "config_source": "preset",
    "preset": "dyrift_trgt_deploy_v1",
    "target_context_groups": "__dataset__",
    "graph_config_overrides": [
      "prototype_multiclass_num_classes=0",
      "prototype_loss_weight=0.0",
      "prototype_neighbor_blend=0.0",
      "prototype_global_blend=0.0",
      "prototype_consistency_weight=0.0",
      "prototype_separation_weight=0.0"
    ]
  }
}
