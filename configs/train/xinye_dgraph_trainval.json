{
  "schema_version": 1,
  "name": "xinye_dgraph_trainval_dyrift_train_parameters",
  "dataset": "xinye_dgraph_trainval",
  "notes": "XinYe train+val induced subgraph baseline. Keeps the original full XinYe benchmark untouched.",
  "train": {
    "model": "dyrift_gnn",
    "preset": "dyrift_trgt_deploy_v1",
    "experiment_name": "stable_xy_trainval_base_70e",
    "run_name": "stable_xy_trainval_base_70e",
    "feature_profile": "utpm_shift_enhanced",
    "feature_dir": "outputs/features/xinye_dgraph_trainval/features_ap32",
    "outdir": "outputs/train",
    "seeds": [42],
    "epochs": 70,
    "batch_size": 512,
    "hidden_dim": 128,
    "rel_dim": 32,
    "fanouts": [15, 10],
    "dropout": 0.12,
    "target_context_groups": [
      "graph_stats",
      "graph_time_detrend",
      "neighbor_similarity",
      "activation_early"
    ],
    "graph_config_overrides": {
      "min_early_stop_epoch": 30
    }
  }
}
