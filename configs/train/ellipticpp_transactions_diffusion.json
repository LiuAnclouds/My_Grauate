{
  "schema_version": 1,
  "name": "ellipticpp_transactions_dyrift_diffusion_train_parameters",
  "dataset": "ellipticpp_transactions",
  "notes": "Diffusion-GNN branch: original DyRIFT-GNN/TRGT backbone plus embedding denoising and diffusion view contrast.",
  "train": {
    "model": "dyrift_gnn",
    "preset": "dyrift_trgt_deploy_v1",
    "experiment_name": "diffusion_dyrift_gnn",
    "run_name": "ellipticpp_transactions_dyrift_diffusion_70e_min30",
    "feature_profile": "utpm_shift_enhanced",
    "feature_dir": "outputs/features/ellipticpp_transactions/features_ap96",
    "outdir": "outputs/train",
    "seeds": [42],
    "epochs": 70,
    "batch_size": 512,
    "hidden_dim": 192,
    "rel_dim": 64,
    "fanouts": [20, 15],
    "dropout": 0.10,
    "target_context_groups": [
      "graph_stats",
      "graph_time_detrend",
      "neighbor_similarity",
      "activation_early"
    ],
    "graph_config_overrides": {
      "min_early_stop_epoch": 30,
      "attention_num_heads": 16,
      "neighbor_sampler": "hybrid",
      "recent_window": 120,
      "recent_ratio": 0.45,
      "time_decay_strength": 2.0,
      "target_time_weight_half_life_days": 20,
      "target_time_weight_floor": 0.35,
      "cold_start_residual_strength": 0.35,
      "pseudo_contrastive_weight": 0.0,
      "embedding_diffusion_weight": 0.002,
      "embedding_diffusion_start_epoch": 1,
      "embedding_diffusion_dim": 192,
      "embedding_diffusion_target": "all",
      "embedding_diffusion_score_loss_weight": 0.001,
      "embedding_diffusion_view_weight": 0.001,
      "embedding_diffusion_view_temperature": 0.2,
      "embedding_diffusion_view_sigma": 0.5,
      "embedding_diffusion_view_mode": "infonce",
      "embedding_diffusion_view_sample_size": 4096
    }
  }
}
