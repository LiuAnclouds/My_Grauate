{
  "schema_version": 1,
  "name": "elliptic_transactions_dyrift_train_parameters",
  "dataset": "elliptic_transactions",
  "notes": "Single-dataset DyRIFT-GNN train parameters. Use with mainline.py train --parameter-file.",
  "train": {
    "model": "dyrift_gnn",
    "preset": "dyrift_trgt_deploy_v1",
    "run_name": "elliptic_transactions_dyrift_70e_min30",
    "feature_profile": "utpm_shift_compact",
    "feature_dir": "outputs/elliptic_transactions/training/features_ap64",
    "outdir": "outputs/elliptic_transactions/training/models",
    "seeds": [42],
    "epochs": 70,
    "batch_size": 512,
    "hidden_dim": 160,
    "rel_dim": 48,
    "fanouts": [20, 15],
    "dropout": 0.15,
    "target_context_groups": [
      "graph_time_detrend",
      "neighbor_similarity",
      "activation_early"
    ],
    "graph_config_overrides": {
      "min_early_stop_epoch": 30,
      "attention_num_heads": 4,
      "internal_risk_fusion": "none",
      "message_risk_strength": 0.0,
      "pseudo_contrastive_start_epoch": 5,
      "pseudo_contrastive_weight": 0.01,
      "prototype_start_epoch": 3,
      "prototype_loss_weight": 0.03,
      "target_time_weight_half_life_days": 20,
      "target_time_weight_floor": 0.35
    }
  }
}
