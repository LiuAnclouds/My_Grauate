{
  "schema_version": 1,
  "notes": "Keep UTGT architecture and teacher/hybrid protocol fixed. This profile records the validated dataset-local attention-head search: ET prefers 4 heads, EPP prefers 16 heads, XinYe keeps the hpsearch1 setting.",
  "mainline": {
    "defaults": {
      "run_name_template": "{suite_name}_{dataset_short}",
      "epochs": 8,
      "batch_size": 512,
      "hidden_dim": 128,
      "rel_dim": 32,
      "fanouts": [15, 10]
    },
    "datasets": {
      "xinye_dgraph": {
        "run_name_template": "thesis_m8_utgt_teacher_hpsearch1_e8_s42_v1_{dataset_short}",
        "feature_subdir": "features_ap32",
        "attr_proj_dim": 32,
        "hidden_dim": 128,
        "rel_dim": 32,
        "fanouts": [15, 10]
      },
      "elliptic_transactions": {
        "run_name_template": "probe_m8_teacher_unified_ap64_hd160_r48_f2015_h4_e8_{dataset_short}",
        "feature_subdir": "features_ap64",
        "attr_proj_dim": 64,
        "hidden_dim": 160,
        "rel_dim": 48,
        "fanouts": [20, 15],
        "graph_config_overrides": {
          "attention_num_heads": 4
        }
      },
      "ellipticpp_transactions": {
        "run_name_template": "probe_m8_teacher_unified_ap64_hd160_r48_f2015_h16_e8_{dataset_short}",
        "feature_subdir": "features_ap64",
        "attr_proj_dim": 64,
        "hidden_dim": 160,
        "rel_dim": 48,
        "fanouts": [20, 15],
        "graph_config_overrides": {
          "attention_num_heads": 16
        }
      }
    }
  },
  "hybrid": {
    "defaults": {
      "blend_alpha": 0.4999,
      "run_name_template": "{suite_name}_{dataset_short}",
      "secondary_run_name_template": "thesis_graphprop_rr0215_hpe_{dataset_short}"
    },
    "datasets": {
      "xinye_dgraph": {
        "base_run_name_template": "thesis_m8_utgt_teacher_hpsearch1_e8_s42_v1_{dataset_short}"
      },
      "elliptic_transactions": {
        "base_run_name_template": "probe_m8_teacher_unified_ap64_hd160_r48_f2015_h4_e8_{dataset_short}"
      },
      "ellipticpp_transactions": {
        "base_run_name_template": "probe_m8_teacher_unified_ap64_hd160_r48_f2015_h16_e8_{dataset_short}"
      }
    }
  }
}
