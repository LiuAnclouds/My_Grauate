{
  "schema_version": 2,
  "notes": "DyRIFT-GNN final pure-GNN thesis suite. Shared defaults live here; dataset-local hyperparameters are split into independent files and referenced through mainline.dataset_files.",
  "mainline": {
    "defaults": {
      "run_name_template": "{suite_name}_{dataset_short}",
      "feature_profile": "utpm_shift_enhanced",
      "target_context_groups": [
        "graph_stats",
        "graph_time_detrend",
        "neighbor_similarity",
        "activation_early"
      ],
      "epochs": 8,
      "batch_size": 512,
      "hidden_dim": 128,
      "rel_dim": 32,
      "fanouts": [15, 10]
    },
    "dataset_files": {
      "xinye_dgraph": "dyrift_gnn/xinye_dgraph.json",
      "elliptic_transactions": "dyrift_gnn/elliptic_transactions.json",
      "ellipticpp_transactions": "dyrift_gnn/ellipticpp_transactions.json"
    }
  }
}
