{
  "schema_version": 1,
  "name": "xinye_dgraph_dyrift_train_parameters",
  "dataset": "xinye_dgraph",
  "notes": "Single-dataset DyRIFT-GNN train parameters. Use with experiment/mainline.py train --parameter-file.",
  "train": {
    "model": "dyrift_gnn",
    "preset": "dyrift_trgt_deploy_v1",
    "run_name": "xinye_dgraph_dyrift_70e_min30",
    "feature_profile": "utpm_shift_enhanced",
    "feature_dir": "experiment/outputs/training/features_ap32",
    "outdir": "experiment/outputs/training/models",
    "seeds": [42],
    "epochs": 70,
    "batch_size": 512,
    "hidden_dim": 128,
    "rel_dim": 32,
    "fanouts": [15, 10],
    "dropout": 0.12,
    "target_context_groups": [
      "graph_stats",
      "graph_time_detrend",
      "neighbor_similarity",
      "activation_early"
    ],
    "graph_config_overrides": {
      "min_early_stop_epoch": 30
    }
  }
}
